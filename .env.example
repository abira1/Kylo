# Claude AI Configuration - Vercel Proxy Setup
# Development: http://localhost:5001 (local backend)
# Production: Update with your Vercel deployment URL from step-by-step guide
VITE_VERCEL_PROXY_URL=https://kylo-cors-proxy.vercel.app

# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=kylo-support
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_DATABASE_URL=https://kylo-support-default-rtdb.asia-southeast1.firebasedatabase.app
