{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd backend && rm -rf node_modules package-lock.json && npm install"
  },
  "deploy": {
    "startCommand": "cd backend && node --no-warnings server-clean.js",
    "restartPolicyMaxRetries": 10
  },
  "buildCache": false,
  "forceFreshBuild": "2025-01-14-v2"
}
