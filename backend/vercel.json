{
  "version": 2,
  "builds": [
    {
      "src": "server-clean.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server-clean.js"
    }
  ],
  "env": {
    "CLAUDE_API_KEY": "@claude_api_key"
  },
  "envObjects": {
    "production": {
      "CLAUDE_API_KEY": "@claude_api_key"
    }
  }
}
