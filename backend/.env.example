# Claude API Configuration
CLAUDE_API_KEY=sk-ant-your-api-key-here

# Backend Server
PORT=5001

# Frontend API URL (set this in frontend .env)
VITE_API_BASE_URL=http://localhost:5001

# ============================================
# EMAIL SERVICE (SendGrid or SMTP)
# ============================================
EMAIL_PROVIDER=sendgrid  # or 'smtp'
EMAIL_FROM=noreply@kylo.ai
EMAIL_REPLY_TO=support@kylo.ai

# SendGrid Configuration
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMTP Configuration (alternative to SendGrid)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# ============================================
# WHATSAPP BUSINESS API
# ============================================
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=kylo-verify-token

# ============================================
# TEAM NOTIFICATIONS
# ============================================
TEAM_ESCALATION_EMAIL=escalations@kylo.ai
TEAM_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# OTP SALT (for secure hashing)
# ============================================
OTP_SALT=kylo-otp-salt-change-in-production

# ============================================
# FIREBASE CONFIGURATION
# ============================================
FIREBASE_SERVICE_ACCOUNT_PATH=./kylo-firebase-key.json
FIREBASE_DATABASE_URL=https://kylo-support.firebaseio.com
FIREBASE_PROJECT_ID=kylo-support

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=development  # development, staging, or production
