{
  "rules": {
    "clients": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('admins').child(auth.uid).val() === true",
        ".write": "auth.uid === $uid",
        ".validate": "newData.hasChildren(['profile'])"
      }
    },
    "admins": {
      ".read": "root.child('admins').child(auth.uid).val() === true",
      ".write": false
    },
    ".read": false,
    ".write": false
  }
}
